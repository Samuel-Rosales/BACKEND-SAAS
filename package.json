{
  "name": "backend-saas",
  "version": "1.0.2",
  "packageManager": "pnpm@11.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "puppeteer"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "description": "",
  "main": "app.js",
  "scripts": {
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/app.ts",
    "build": "pnpm prisma generate && tsc && tsc-alias",
    "start": "pnpm prisma migrate deploy && node dist/app.js",
    "prisma:generate": "prisma generate",
    "prisma:format": "pnpx prisma format",
    "prisma:push": "pnpx prisma db push",
    "prisma:studio": "pnpx prisma studio",
    "prisma:seed": "pnpx prisma db seed",
    "prisma:migrate": "pnpx prisma migrate dev",
    "db:reset": "pnpx prisma migrate reset"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Samuel-Rosales/BACKEND-SAAS.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Samuel-Rosales/BACKEND-SAAS/issues"
  },
  "homepage": "https://github.com/Samuel-Rosales/BACKEND-SAAS#readme",
  "dependencies": {
    "@nestjs/common": "^11.1.11",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "axios": "^1.13.4",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "hashids": "^2.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.0.3",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "nodemon": "^3.1.11",
    "prisma": "^7.2.0",
    "prisma-erd-generator": "^2.4.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
