// 1. Configuración inicial
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// USUARIOS Y SEGURIDAD (RBAC)
// ==========================================

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  ci        String   @unique // Cédula de identidad
  password  String   // Hash de la contraseña (nunca texto plano)
  name      String
  phone     String
  
  // Relaciones
  memberships BusinessMember[] // Un usuario puede trabajar en varios negocios
  createdProducts Product[]    // Auditoría: qué productos creó/editó
}

model Role {
  id      Int              @id @default(autoincrement())
  name    String           @unique // Ej: "Administrador", "Cajero"
  code    String           @unique // Ej: "ADMIN", "CASHIER" (para uso interno en código)
  members BusinessMember[]
}

// Tabla pivote: Relaciona Usuario <-> Negocio con un Rol específico
model BusinessMember {
  id         Int      @id @default(autoincrement())
  userId     Int
  businessId Int
  roleId     Int
  isActive   Boolean  @default(true) // Si se despide al empleado, se pasa a false
  joinedAt   DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  business   Business @relation(fields: [businessId], references: [id])
  role       Role     @relation(fields: [roleId], references: [id])

  // Relaciones de auditoría y operación
  sales          Sale[]
  purchases      Purchase[]
  stockMovements StockMovement[]
  cashRegisters  CashRegister[]

  @@index([userId])
  @@index([businessId])
}

// ==========================================
// NÚCLEO DEL NEGOCIO (TENANT)
// ==========================================

model Business {
  id             Int      @id @default(autoincrement())
  name           String
  currencySymbol String   @default("$") // Símbolo visual ($, Bs)
  exchangeRate   Decimal  @default(1.0) @db.Decimal(10, 4) // Tasa base global actual
  address        String?
  logoUrl        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relaciones
  subscription   Subscription?
  members        BusinessMember[]
  exchangeRates  ExchangeRate[]
  categories     Category[]
  products       Product[]
  clients        Client[]
  suppliers      Supplier[]
  sales          Sale[]
  purchases      Purchase[]
  depots         Depot[]
  stockMovements StockMovement[]
  cashRegisters  CashRegister[]
}

model Subscription {
  id             Int       @id @default(autoincrement())
  businessId     Int       @unique // Relación 1 a 1 estricta
  planType       PlanType  @default(TRIAL) // Usamos Enum para evitar errores de texto
  status         SubStatus @default(ACTIVE)
  startDate      DateTime  @default(now())
  endDate        DateTime
  lastPaymentRef String

  business Business @relation(fields: [businessId], references: [id])
}

model ExchangeRate {
  id          Int      @id @default(autoincrement())
  businessId  Int
  currency    String   // Ej: "VES", "USD" (ISO Code)
  rate        Decimal  @db.Decimal(10, 4) // Ej: 54.3000 (4 decimales para precisión)
  createdAt   DateTime @default(now()) // Histórico: permite ver cuánto valía el dólar hace 1 mes
  createdById Int

  business Business @relation(fields: [businessId], references: [id])

  // Relaciones inversas: Usadas para saber a qué tasa se pagó una venta antigua
  sales           Sale[]
  salePayments    SalePayment[]
  purchases       Purchase[]
  purchasePayments PurchasePayment[]
  cashCounts      CashCount[]
}

// ==========================================
// INVENTARIO Y PRODUCTOS
// ==========================================

model Depot {
  id         Int      @id @default(autoincrement())
  businessId Int
  name       String   // Ej: "Almacén Principal", "Sucursal Centro"
  location   String

  business Business @relation(fields: [businessId], references: [id])

  // Relaciones
  stockGenerals  StockGeneral[]
  stockLots      StockLot[]
  stockMovements StockMovement[]
}

model Category {
  id         Int    @id @default(autoincrement())
  businessId Int
  name       String

  business Business  @relation(fields: [businessId], references: [id])
  products Product[]
}

model Product {
  id           Int      @id @default(autoincrement())
  businessId   Int
  categoryId   Int
  name         String
  sku          String?  // Código de barras o identificador único
  description  String?
  imageUrl     String?
  costPrice    Decimal  @default(0) @db.Decimal(15, 2)
  salePrice    Decimal  @default(0) @db.Decimal(15, 2)
  minStock     Int      @default(0) // Alerta de stock bajo
  isService    Boolean  @default(false) // Si es true, no controla stock
  isPerishable Boolean  @default(false)
  updatedAt    DateTime @updatedAt
  updatedById  Int?

  business  Business  @relation(fields: [businessId], references: [id])
  category  Category  @relation(fields: [categoryId], references: [id])
  updatedBy User?     @relation(fields: [updatedById], references: [id])

  // Relaciones
  stockGenerals  StockGeneral[]
  stockLots      StockLot[]
  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]
  stockMovements StockMovement[]

  @@index([businessId, sku]) // Índice para búsquedas rápidas por código de barras
}

// STOCK GENERAL: Cantidad total por almacén (Lectura rápida)
model StockGeneral {
  productId Int
  depotId   Int
  quantity  Int @default(0)

  product Product @relation(fields: [productId], references: [id])
  depot   Depot   @relation(fields: [depotId], references: [id])

  // CLAVE COMPUESTA: Evita duplicados. Solo una fila por Producto+Depósito
  @@id([productId, depotId])
}

// STOCK POR LOTES: Control FIFO y Vencimientos
model StockLot {
  id             Int       @id @default(autoincrement())
  productId      Int
  depotId        Int
  quantity       Int       // Cantidad ACTUAL disponible en este lote
  expirationDate DateTime  @db.Date // Solo fecha, sin hora
  lotCost        Decimal   @db.Decimal(15, 2) // Costo específico de este lote
  createdAt      DateTime  @default(now())

  product Product @relation(fields: [productId], references: [id])
  depot   Depot   @relation(fields: [depotId], references: [id])
  
  // Relación con ventas (Trazabilidad)
  saleItemLots SaleItemLot[]

  @@index([productId, expirationDate]) // Útil para buscar qué vence pronto
}

model StockMovement {
  id          Int          @id @default(autoincrement())
  businessId  Int
  productId   Int
  memberId    Int
  depotId     Int
  type        MovementType // IN, OUT, ADJUSTMENT, TRANSFER
  quantity    Int          // Positivo o negativo según el tipo
  reason      String?      // "Venta #123", "Merma", "Compra #45"
  date        DateTime     @default(now())

  business Business       @relation(fields: [businessId], references: [id])
  product  Product        @relation(fields: [productId], references: [id])
  member   BusinessMember @relation(fields: [memberId], references: [id])
  depot    Depot          @relation(fields: [depotId], references: [id])
}

// ==========================================
// VENTAS (SALES)
// ==========================================

model Client {
  id         Int     @id @default(autoincrement())
  businessId Int
  name       String
  ci         String // Cédula / RIF / DNI
  phone      String?
  email      String?
  address    String?

  business Business @relation(fields: [businessId], references: [id])
  sales    Sale[]
}

model Sale {
  id               Int        @id @default(autoincrement())
  businessId       Int
  receiptNumber    Int        // Consecutivo visual para el cliente (Factura #001)
  memberId         Int        // Vendedor
  clientId         Int
  type             SaleType   @default(RETAIL)
  status           SaleStatus @default(COMPLETED)
  
  // Totales
  totalAmount      Decimal    @db.Decimal(15, 2)
  remainingBalance Decimal    @default(0) @db.Decimal(15, 2) // Deuda pendiente (si es a crédito)
  paymentDueDate   DateTime?  // Fecha límite para pagar (si es a crédito)
  
  exchangeRateId   Int        // Tasa del día usada para la conversión
  createdAt        DateTime   @default(now()) 
  updatedAt        DateTime   @updatedAt

  business     Business       @relation(fields: [businessId], references: [id])
  member       BusinessMember @relation(fields: [memberId], references: [id])
  client       Client         @relation(fields: [clientId], references: [id])
  exchangeRate ExchangeRate   @relation(fields: [exchangeRateId], references: [id])

  items    SaleItem[]
  payments SalePayment[]
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int
  productId Int
  quantity  Int
  unitPrice Decimal @db.Decimal(15, 2) // Precio al momento de la venta
  subTotal  Decimal @db.Decimal(15, 2)

  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  // Detalle de qué lotes se usaron para esta línea de venta
  lotAllocations SaleItemLot[]
}

// TABLA DE TRAZABILIDAD EXACTA
model SaleItemLot {
  id          Int @id @default(autoincrement())
  saleItemId  Int
  stockLotId  Int
  quantity    Int // Cuántos items se sacaron de ESTE lote específico

  saleItem SaleItem @relation(fields: [saleItemId], references: [id])
  stockLot StockLot @relation(fields: [stockLotId], references: [id])
}

model SalePayment {
  id             Int      @id @default(autoincrement())
  saleId         Int
  paymentMethodId Int
  paymentMethod  PaymentMethod @relation(fields: [paymentMethodId], references: [id]) // EFECTIVO, PAGO_MOVIL, ZELLE, ETC
  amount         Decimal  @db.Decimal(15, 2)
  currency       String   // Moneda del pago (ej: USD)
  exchangeRateId Int      // Si pagaron en Bs, qué tasa se usó
  reference      String   // Nro de referencia bancaria
  date           DateTime @default(now())

  sale         Sale          @relation(fields: [saleId], references: [id])
  exchangeRate ExchangeRate  @relation(fields: [exchangeRateId], references: [id])
}

// ==========================================
// COMPRAS Y PROVEEDORES
// ==========================================

model Supplier {
  id         Int     @id @default(autoincrement())
  businessId Int
  name       String
  contact    String?
  phone      String?

  business  Business   @relation(fields: [businessId], references: [id])
  purchases Purchase[]
}

model Purchase {
  id             Int            @id @default(autoincrement())
  businessId     Int
  supplierId     Int
  memberId       Int            // Quién registró la compra
  totalCost      Decimal        @db.Decimal(15, 2)
  status         PurchaseStatus @default(COMPLETED)
  exchangeRateId Int
  date           DateTime       @default(now())

  business     Business       @relation(fields: [businessId], references: [id])
  supplier     Supplier       @relation(fields: [supplierId], references: [id])
  member       BusinessMember @relation(fields: [memberId], references: [id])
  exchangeRate ExchangeRate   @relation(fields: [exchangeRateId], references: [id])

  items    PurchaseItem[]
  payments PurchasePayment[]
}

model PurchaseItem {
  id         Int     @id @default(autoincrement())
  purchaseId Int
  productId  Int
  quantity   Int
  unitCost   Decimal @db.Decimal(15, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  // Lotes generados por esta compra
  generatedLots ItemLot[]
}

// Histórico: Qué lotes entraron con esta compra específica
model ItemLot {
  id             Int       @id @default(autoincrement())
  purchaseItemId Int
  quantity       Int
  unitCost       Decimal   @db.Decimal(15, 2)
  expirationDate DateTime  @db.Date

  purchaseItem PurchaseItem @relation(fields: [purchaseItemId], references: [id])
}

model PurchasePayment {
  id             Int      @id @default(autoincrement())
  purchaseId     Int
  paymentMethodId         Int
  paymentMethod  PaymentMethod @relation(fields: [paymentMethodId], references: [id]) // EFECTIVO, PAGO_MOVIL, ZELLE, ETC
  amount         Decimal  @db.Decimal(15, 2)
  currency       String
  exchangeRateId Int
  reference      String
  paymentDate    DateTime @default(now())

  purchase     Purchase      @relation(fields: [purchaseId], references: [id])
  exchangeRate ExchangeRate  @relation(fields: [exchangeRateId], references: [id])
}

// ==========================================
// CAJA (CASH REGISTER)
// ==========================================

model CashRegister {
  id            Int        @id @default(autoincrement())
  businessId    Int
  memberId      Int
  status        CashStatus @default(OPEN)
  openTime      DateTime   @default(now())
  closeTime     DateTime?
  initialAmount Decimal    @default(0) @db.Decimal(15, 2)
  finalAmount   Decimal?   @db.Decimal(15, 2)

  business Business       @relation(fields: [businessId], references: [id])
  member   BusinessMember @relation(fields: [memberId], references: [id])
  counts   CashCount[]
}

model CashCount {
  id             Int     @id @default(autoincrement())
  cashRegisterId Int
  denomination   Decimal @db.Decimal(10, 2) // Ej: Billete de 10, de 20...
  quantity       Int     // Cuántos billetes de esa denominación
  currency       String  // USD, VES
  exchangeRateId Int
  type           CashCountType // INITIAL (apertura) o FINAL (cierre)

  cashRegister CashRegister  @relation(fields: [cashRegisterId], references: [id])
  exchangeRate ExchangeRate @relation(fields: [exchangeRateId], references: [id])
}

model PaymentMethod {
  id         Int      @id @default(autoincrement())
  name       String   // Ej: "Zelle Banesco", "Caja Chica", "Punto de Venta"
  type       PaymentType // El tipo "interno" para que el sistema sepa cómo comportarse
  isActive   Boolean  @default(true) // Para ocultar cuentas viejas sin borrar historial

  
  // Relaciones con los pagos realizados
  salePayments     SalePayment[]
  purchasePayments PurchasePayment[]

  @@unique([name]) // Evita que creen dos veces "Zelle Banesco"
}

// ==========================================
// ENUMS (Listas fijas de valores)
// ==========================================

enum PlanType {
  TRIAL
  BASIC
  PREMIUM
  ENTERPRISE
}

enum SubStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELLED
}

enum MovementType {
  IN          // Entrada (Compra)
  OUT         // Salida (Venta)
  ADJUSTMENT  // Ajuste manual (Inventario físico)
  TRANSFER    // Movimiento entre bodegas
  RETURN      // Devolución
}

enum SaleType {
  RETAIL
  WHOLESALE
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PurchaseStatus {
  ORDERED
  COMPLETED
  RECEIVED
  CANCELLED
}

enum PaymentType {
  CASH
  DEBIT_CARD
  CREDIT_CARD
  TRANSFER
  MOBILE_PAYMENT
  ZELLE
  OTHER
}

enum CashStatus {
  OPEN
  CLOSED
}

enum CashCountType {
  INITIAL
  FINAL
  AUDIT // Arqueo sorpresa
}