// 1. Configuración inicial
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// USUARIOS Y SEGURIDAD (RBAC)
// ==========================================

enum PermissionModule {
  BUSINESS
  MEMBERS
  CLIENTS
  SUPPLIERS
  PRODUCTS
  CATEGORIES
  PRESENTATIONS
  DEPOSITS
  STOCK
  CASH_REGISTER
  CREDITS
  SALES
  PROCUREMENT
  REPORTS
  FINANCE
  INVENTORY
  RESTAURANT
}

model User {
  id       Int    @id @default(autoincrement())
  ci       String @unique // Cédula de identidad
  password String // Hash de la contraseña (nunca texto plano)
  name     String

  // Plataforma
  // Si es true, puede seleccionar cualquier business vía header x-business-id
  // sin requerir un BusinessMember activo (membresía).
  isSuperAdmin Boolean @default(false)

  contacts UserContact?

  // Relaciones
  memberships     BusinessMember[] // Un usuario puede trabajar en varios negocios
  createdProducts Product[] // Auditoría: qué productos creó/editó

  // Plataforma - Pagos de Suscripción
  createdSubscriptionPayments  SubscriptionPayment[] @relation("SubscriptionPaymentCreatedBy")
  reviewedSubscriptionPayments SubscriptionPayment[] @relation("SubscriptionPaymentReviewedBy")
}

model UserContact {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  email   String @unique
  phone   String
  address String
  city    String
  state   String
}

model Role {
  id      Int              @id @default(autoincrement())
  name    String           @unique // Ej: "Administrador", "Cajero"
  code    String           @unique // Ej: "ADMIN", "CASHIER" (para uso interno en código)
  members BusinessMember[]
  permissions RolePermission[]
}

model Permission {
  id          Int              @id @default(autoincrement())
  code        String           @unique
  name        String
  description String?
  module      PermissionModule
  roles       RolePermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// Tabla pivote: Relaciona Usuario <-> Negocio con un Rol específico
model BusinessMember {
  id         Int      @id @default(autoincrement())
  userId     Int
  businessId Int
  roleId     Int
  isActive   Boolean  @default(true) // Si se despide al empleado, se pasa a false
  joinedAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  business Business @relation(fields: [businessId], references: [id])
  role     Role     @relation(fields: [roleId], references: [id])

  // Relaciones de auditoría y operación
  sales          Sale[]
  purchases      Purchase[]
  stockMovements StockMovement[]
  cashRegisters  CashRegister[]

  @@index([userId])
  @@index([businessId])
}

// ==========================================
// NÚCLEO DEL NEGOCIO (TENANT)
// ==========================================

model Business {
  id           Int     @id @default(autoincrement())
  name         String

  businessCategoryId Int
  businessCategory   BusinessCategory @relation(fields: [businessCategoryId], references: [id])

  address   String
  logoUrl   String? // Logo del negocio
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // CONFIGURACIÓN DE TASA
  // Define de dónde sacaremos el valor para mostrar en el Frontend hoy
  rateStrategy ExchangeRateStrategy @default(MANUAL)
  
  // Si es MANUAL, usamos este valor. 
  // Si es API_*, este campo se ignora (o se usa como fallback).
  manualRate   Decimal?             @db.Decimal(10, 4) 

  // Este campo "exchangeRate" que tenías antes, lo mantenemos pero
  // conceptualmente será el "Valor Actual Calculado" (cache) para no
  // tener que consultar la estrategia en cada lectura de producto.
  currentExchangeRate Decimal @default(1.0) @db.Decimal(10, 4) 

  // POLÍTICA GLOBAL
  defaultCreditLimit Decimal @default(100) @db.Decimal(15, 2) // Ej: Todos nacen con $100
  enableGlobalCredit Boolean @default(true) // Interruptor general

  // Relaciones
  exchangeRates ExchangeRate[] // Historial de tasas creadas por este negocio

  // Relaciones
  subscription   Subscription?
  subscriptionPayments SubscriptionPayment[]
  members        BusinessMember[]
  categories     Category[]
  products       Product[]
  clients        Client[]
  suppliers      Supplier[]
  sales          Sale[]
  purchases      Purchase[]
  depots         Depot[]
  stockMovements StockMovement[]
  cashRegisters  CashRegister[]
  restaurantTables RestaurantTable[]
  orders           Order[]
}

model BusinessCategory {
  id          Int    @id @default(autoincrement())
  name        String
  description String
  isRestaurant Boolean @default(false)

  businesses Business[]
}

// ==========================================
// PLANES DE SUSCRIPCIÓN (CATÁLOGO)
// ==========================================

model SubscriptionPlan {
  id          Int     @id @default(autoincrement())
  // Código estable para compatibilidad con el enum existente (TRIAL, BASIC, ...)
  code        String  @unique
  name        String
  description String?

  isActive Boolean @default(true)

  // Metadatos de funcionalidades/límites. Se deja opcional para no forzar writes.
  entitlements Json?

  // Precio base mensual (1 moneda). Puede convivir con precios por duración.
  priceMonthly Decimal @default(0) @db.Decimal(15, 2)

  prices SubscriptionPlanPrice[]

  subscriptions        Subscription[]
  subscriptionPayments SubscriptionPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubscriptionPlanPrice {
  id     Int @id @default(autoincrement())
  planId Int
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  // Duración en meses: 1, 3, 6, 12
  months Int
  price  Decimal @db.Decimal(15, 2)

  isActive Boolean @default(true)

  @@unique([planId, months])
}

model Subscription {
  id             Int       @id @default(autoincrement())
  businessId     Int       @unique // Relación 1 a 1 estricta
  planType       PlanType  @default(TRIAL) // Usamos Enum para evitar errores de texto

  // Nuevo: relación a catálogo de planes. Se mantiene opcional por compatibilidad y migración gradual.
  planId Int?
  plan   SubscriptionPlan? @relation(fields: [planId], references: [id])

  status         SubStatus @default(ACTIVE)
  startDate      DateTime  @default(now())
  endDate        DateTime
  lastPaymentRef String

  business Business @relation(fields: [businessId], references: [id])

  payments SubscriptionPayment[]
}

model SubscriptionPayment {
  id             Int      @id @default(autoincrement())

  businessId     Int
  subscriptionId Int

  // Quién registró el pago (usuario del negocio)
  createdById    Int

  // Revisión (solo admin/super-admin)
  reviewedById   Int?
  reviewedAt     DateTime?
  reviewNote     String?

  planType       PlanType

  // Nuevo: relación a catálogo de planes. Se mantiene opcional por compatibilidad y migración gradual.
  planId Int?
  plan   SubscriptionPlan? @relation(fields: [planId], references: [id])

  monthsPurchased Int

  amount         Decimal  @db.Decimal(15, 2)
  currency       Currency

  // Referencia bancaria / comprobante
  reference      String
  proofUrl       String?

  status         SubscriptionPaymentStatus @default(UNDER_REVIEW)
  createdAt      DateTime  @default(now())

  business       Business     @relation(fields: [businessId], references: [id])
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  createdBy      User         @relation("SubscriptionPaymentCreatedBy", fields: [createdById], references: [id])
  reviewedBy     User?        @relation("SubscriptionPaymentReviewedBy", fields: [reviewedById], references: [id])

  @@index([businessId, status, createdAt])
  @@unique([businessId, reference])
}

model ExchangeRate {
  id          Int      @id @default(autoincrement())
  businessId  Int?

  rate        Decimal  @db.Decimal(10, 4) // Ej: 54.3000 (4 decimales para precisión)
  createdAt   DateTime @default(now()) // Histórico: permite ver cuánto valía el dólar hace 1 mes
  isActive    Boolean  @default(true)

  source    ExchangeRateStrategy @default(MANUAL)

  business  Business? @relation(fields: [businessId], references: [id])
  // Relaciones inversas: Usadas para saber a qué tasa se pagó una venta antigua
  sales            Sale[]
  salePayments     SalePayment[]
  purchases        Purchase[]
  purchasePayments PurchasePayment[]
  cashCounts       CashCount[]
  creditNotePayments CreditNotePayment[]

  @@index([createdAt])
}

model Tax {
  id          Int      @id @default(autoincrement())
  //businessId  Int      // Cada negocio podría configurar sus impuestos si aplica, o lo haces global
  name        String   // Ej: "IVA General", "Exento", "Alicuota Reducida"
  rate        Decimal  @db.Decimal(5, 4) // 0.1600, 0.0000, 0.0800
  code        String?  // Para facturación electrónica (si aplica)
  isActive    Boolean  @default(true)

  products    Product[]
  purchases   Purchase[]
  // Opcional: Si los impuestos son estándar para todos los tenants, quita businessId
  //business    Business @relation(fields: [businessId], references: [id])
}

// ==========================================
// INVENTARIO Y PRODUCTOS
// ==========================================

model Depot {
  id         Int     @id @default(autoincrement())
  businessId Int
  name       String
  location   String
  isActive   Boolean @default(true)

  business       Business        @relation(fields: [businessId], references: [id])
  purchaseItems  PurchaseItem[]
  stockLots      StockLot[]
  stockMovements StockMovement[]
}

model MeasurementUnit {
  id       Int     @id @default(autoincrement())
  name     String // "Kilogramo", "Unidad", "Litro"
  symbol   String // "kg", "und", "L"
  type     UnitType
  isActive Boolean @default(true)

  products Product[]
}

model Category {
  id         Int     @id @default(autoincrement())
  businessId Int
  name       String
  description String? @default("")
  isActive   Boolean  @default(true)
  //parentId   Int?     // Recomendado: Para subcategorías (Electrónica -> Celulares)

  business Business @relation(fields: [businessId], references: [id])
  //parent   Category? @relation("SubCategories", fields: [parentId], references: [id])
  //children Category[] @relation("SubCategories")

  products Product[]
}

model Product {
  id            Int     @id @default(autoincrement())
  businessId    Int
  categoryId    Int
  unitId        Int
  taxId         Int
  
  name          String
  sku           String?
  description   String? @default("")
  imageUrl      String?
  imagePublicId String?

  // --- COMPORTAMIENTO ---
  // Reemplaza a isService. Define CÓMO se comporta el producto.
  type          ProductType @default(SIMPLE) 
  
  // Se mantiene. Define si pedimos fecha de vencimiento al comprar.
  isPerishable  Boolean @default(false) 

  // --- FINANZAS ---
  costPrice     Decimal @default(0) @db.Decimal(18, 6)
  profitMargin  Decimal @default(0) @db.Decimal(5, 4)
  salePrice     Decimal @default(0) @db.Decimal(18, 2)

  // --- STOCK ---
  minStock      Int     @default(0)

  updatedAt     DateTime @updatedAt
  isActive      Boolean  @default(true)
  updatedById   Int?

  // RELACIONES
  business      Business        @relation(fields: [businessId], references: [id])
  category      Category        @relation(fields: [categoryId], references: [id])
  unit          MeasurementUnit @relation(fields: [unitId], references: [id])
  tax           Tax             @relation(fields: [taxId], references: [id])
  updatedBy     User?           @relation(fields: [updatedById], references: [id])

  // Relaciones Transaccionales
  stockLots       StockLot[]
  saleItems       SaleItem[]
  purchaseItems   PurchaseItem[]
  stockMovements  StockMovement[]
  presentations   ProductPresentation[]
  creditNotes     CreditNoteItem[]
  orderItems      OrderItem[]

  // --- RELACIONES DE RECETAS / COMBOS (La Magia) ---
  // 1. Si este producto es un PLATO (Composite), aquí están sus ingredientes:
  components      ProductComponent[] @relation("ParentProduct")

  // 2. Si este producto es un INGREDIENTE (Simple), aquí dice en qué platos se usa:
  componentOf     ProductComponent[] @relation("ChildProduct")

  @@index([businessId, sku])
}

// TABLA DE RELACIÓN (La Receta / BOM)
model ProductComponent {
  id              Int @id @default(autoincrement())
  
  parentProductId Int // El ID del Plato (Hamburguesa)
  childProductId  Int // El ID del Ingrediente (Carne)
  
  // Cantidad necesaria para hacer 1 unidad del padre
  quantity        Decimal @db.Decimal(18, 6) 

  parent  Product @relation("ParentProduct", fields: [parentProductId], references: [id])
  child   Product @relation("ChildProduct", fields: [childProductId], references: [id])

  @@index([parentProductId])
  @@index([childProductId])
}

model ProductPresentation {
  id        Int     @id @default(autoincrement())
  productId Int
  name      String // "Caja x12"
  factor    Decimal @db.Decimal(18, 6)
  barCode   String?
  price     Decimal @db.Decimal(15, 2)

  isActive Boolean @default(true) // <--- NUEVO: Para Soft Delete

  product Product @relation(fields: [productId], references: [id])

  // Relaciones necesarias para verificar uso (Asumiendo que actualizas tus items)
  saleItems     SaleItem[] // <--- Debes tener esto en tu modelo SaleItem
  purchaseItems PurchaseItem[] // <--- Debes tener esto en tu modelo PurchaseItem
}

model StockLot {
  id             Int      @id @default(autoincrement())
  productId      Int
  depotId        Int
  quantity       Decimal @db.Decimal(18, 6)
  expirationDate DateTime @db.Date
  lotCost        Decimal  @db.Decimal(18, 6)
  createdAt      DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  depot   Depot   @relation(fields: [depotId], references: [id])

  saleItemLots SaleItemLot[]
  movements    StockMovement[]

  // --- ÍNDICES ESTRATÉGICOS (NO LOS OLVIDES) ---
  @@index([productId, expirationDate]) // FIFO/FEFO (Ventas)
  @@index([productId, depotId]) // Totales Rápidos (Dashboard)
}

model StockMovement {
  id         Int          @id @default(autoincrement())
  businessId Int
  productId  Int
  memberId   Int
  depotId    Int
  type       MovementType
  quantity   Decimal @db.Decimal(18, 6)

  // --- SNAPSHOT FINANCIERO ---
  historicalCost Decimal @default(0) @db.Decimal(18, 6) // Cuánto costaba unitariamente en ese momento

  reason String?
  date   DateTime @default(now())
  
  stockLotId  Int?               // <--- El signo ? lo hace opcional
  stockLot    StockLot? @relation(fields: [stockLotId], references: [id])

  business Business       @relation(fields: [businessId], references: [id])
  product  Product        @relation(fields: [productId], references: [id])
  member   BusinessMember @relation(fields: [memberId], references: [id])
  depot    Depot          @relation(fields: [depotId], references: [id])
}

// ==========================================
// VENTAS (SALES)
// ==========================================

model Client {
  id         Int     @id @default(autoincrement())
  businessId Int
  name       String
  ci         String // Cédula / RIF / DNI
  phone      String?
  email      String?
  address    String?
  isActive   Boolean @default(true)

  currentDebt Decimal @default(0) @db.Decimal(15, 2)

  allowCredit     Boolean @default(true)  // ¿Este cliente específico puede pedir fiado?
  useCustomLimit  Boolean @default(false) // ¿Ignoramos el límite del negocio?
  customLimit     Decimal @default(0) @db.Decimal(15, 2) // Solo se usa si useCustomLimit = true
  createdAt       DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
  sales    Sale[]
  orders   Order[]
}

model Sale {
  id            Int @id @default(autoincrement())
  businessId    Int
  receiptNumber Int // Factura #001

  // Relaciones
  memberId       Int
  clientId       Int
  exchangeRateId Int

  // Clasificación
  type   SaleType   @default(RETAIL)
  status SaleStatus @default(COMPLETED) // COMPLETED, CANCELLED, DRAFT

  // --- CONDICIONES DE PAGO ---
  conditions Conditions @default(CASH) // CASH o CREDIT

  // Este estado se calcula automáticamente al pagar. 
  // Eliminé OVERDUE y CANCELLED de aquí porque eso se deduce de otras variables.
  paymentStatus PaymentStatus @default(PAID)

  // --- MONTOS (Desglose fiscal) ---
  subTotal    Decimal @db.Decimal(15, 2) // Precio antes de impuestos
  taxAmount   Decimal @db.Decimal(15, 2) // El monto del IVA
  discount    Decimal @default(0) @db.Decimal(15, 2) // Descuentos aplicados
  totalAmount Decimal @db.Decimal(15, 2) // (SubTotal - Desc) + Tax

  // --- CRÉDITO ---
  remainingBalance Decimal   @default(0) @db.Decimal(15, 2)
  paymentDueDate   DateTime?

  // Auditoría
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft Delete (Anulación lógica)

  // Relaciones
  business     Business       @relation(fields: [businessId], references: [id])
  member       BusinessMember @relation(fields: [memberId], references: [id])
  client       Client         @relation(fields: [clientId], references: [id])
  exchangeRate ExchangeRate   @relation(fields: [exchangeRateId], references: [id])

  items       SaleItem[]
  payments    SalePayment[]
  creditNotes CreditNote[]

  installments SaleInstallment[]
}

model SaleInstallment {
  id          Int      @id @default(autoincrement())
  saleId      Int
  number      Int      // Cuota #1, #2...

  amount      Decimal  @db.Decimal(15, 2)
  amountPaid  Decimal  @default(0) @db.Decimal(15, 2)

  dueDate     DateTime @db.Date
  status      InstallmentStatus @default(PENDING)
  paidAt      DateTime?

  sale        Sale     @relation(fields: [saleId], references: [id])
}

model CreditNote {
  id         Int @id @default(autoincrement())
  businessId Int
  saleId     Int // Vinculada a la venta original
  number     Int // Consecutivo fiscal (Nota de Crédito #001)

  totalAmount Decimal @db.Decimal(15, 2) // Cuánto dinero se devuelve
  reason      String // "Producto defectuoso", "No le quedó", etc.

  createdAt DateTime @default(now())

  sale  Sale             @relation(fields: [saleId], references: [id])
  items CreditNoteItem[]
  creditNotePayments CreditNotePayment[]
}

// Detalle de qué items específicos se devolvieron
model CreditNoteItem {
  id           Int     @id @default(autoincrement())
  creditNoteId Int
  productId    Int
  quantity     Decimal @db.Decimal(18, 6) // Cantidad que entra de vuelta al stock
  unitPrice    Decimal @db.Decimal(16, 2)// Precio al que se vendió originalmente
  subTotal     Decimal @db.Decimal(16, 2)

  returnToStock Boolean @default(true)

  creditNote CreditNote @relation(fields: [creditNoteId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])
}

model CreditNotePayment {
  id              Int      @id @default(autoincrement())
  creditNoteId    Int
  paymentMethodId Int
  
  amount          Decimal  @db.Decimal(15, 2)
  reference       String?  // Referencia bancaria si es Zelle
  createdAt       DateTime @default(now())

  exchangeRateId  Int      // La tasa usada para la conversión
  exchangeRate    ExchangeRate @relation(fields: [exchangeRateId], references: [id])

  // --- EL TRUCO DE MAGIA ---
  // Relacionamos el pago con la caja.
  // Si es EFECTIVO, llenamos este campo. Si es ZELLE, lo dejamos null.
  cashRegisterId  Int?     
  cashRegister    CashRegister? @relation(fields: [cashRegisterId], references: [id])

  creditNote      CreditNote    @relation(fields: [creditNoteId], references: [id])
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
}

model SaleItem {
  id                    Int     @id @default(autoincrement())
  saleId                Int
  productId             Int
  productPresentationId Int? // <--- NUEVO: Presentación usada (caja, pack, unidad)
  quantity              Decimal @db.Decimal(18, 6)
  unitPrice             Decimal @db.Decimal(15, 2) // Precio al momento de la venta
  subTotal              Decimal @db.Decimal(15, 2)

  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  // Detalle de qué lotes se usaron para esta línea de venta
  lotAllocations SaleItemLot[]

  productPresentation ProductPresentation? @relation(fields: [productPresentationId], references: [id])
}

// TABLA DE TRAZABILIDAD EXACTA
model SaleItemLot {
  id         Int @id @default(autoincrement())
  saleItemId Int
  stockLotId Int
  quantity   Decimal @db.Decimal(18, 6)// Cuántos items se sacaron de ESTE lote específico

  saleItem SaleItem @relation(fields: [saleItemId], references: [id])
  stockLot StockLot @relation(fields: [stockLotId], references: [id])
}

model SalePayment {
  id              Int           @id @default(autoincrement())
  saleId          Int
  paymentMethodId Int
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id]) // EFECTIVO, PAGO_MOVIL, ZELLE, ETC
  amount          Decimal       @db.Decimal(15, 2)

  exchangeRateId  Int // Si pagaron en Bs, qué tasa se usó

  reference       String // Nro de referencia bancaria
  date            DateTime      @default(now())

  cashRegisterId  Int? 
  cashRegister    CashRegister? @relation(fields: [cashRegisterId], references: [id])

  sale         Sale         @relation(fields: [saleId], references: [id])
  exchangeRate ExchangeRate @relation(fields: [exchangeRateId], references: [id])
}

// ==========================================
// COMPRAS Y PROVEEDORES
// ==========================================

model Supplier {
  id          Int     @id @default(autoincrement())
  businessId  Int
  nameCompany String
  contactName String
  address     String
  phone       String
  isActive    Boolean @default(true)

  business  Business   @relation(fields: [businessId], references: [id])
  purchases Purchase[]
}

model Purchase {
  id         Int @id @default(autoincrement())
  businessId Int
  supplierId Int
  memberId   Int // Quién registró la compra

  // --- 1. LO QUE LE FALTABA: Desglose Financiero ---
  subTotal  Decimal @db.Decimal(15, 2) // Suma de items sin impuestos
  taxAmount Decimal @db.Decimal(15, 2) // Monto de Impuestos/IVA
  totalCost Decimal @db.Decimal(15, 2) // Total Final a Pagar (SubTotal + Tax)

  status         PurchaseStatus @default(COMPLETED)
  exchangeRateId Int

  // --- 2. LO QUE LE FALTABA: Datos Administrativos ---
  reference   String? // Nro Factura Física del Proveedor (Ej: "A-00045")
  observation String // Notas: "Caja llegó abierta", "Sin novedad"

  createdAt DateTime  @default(now())

  conditions      Conditions @default(CASH) // CONTADO o CREDITO
  paymentStatus   PaymentStatus     @default(PAID) // PENDING, PARTIAL, PAID
  
  remainingBalance Decimal @default(0) @db.Decimal(15, 2) // Cuánto falta por pagar
  paymentDueDate   DateTime? // Fecha límite final (o fecha de la primera cuota, según lógica)

  taxId     Int 
  tax       Tax @relation(fields: [taxId], references: [id])

  // Relación con las nuevas Cuotas
  installments    PurchaseInstallment[]
  // Relaciones
  business     Business       @relation(fields: [businessId], references: [id])
  supplier     Supplier       @relation(fields: [supplierId], references: [id])
  member       BusinessMember @relation(fields: [memberId], references: [id])
  exchangeRate ExchangeRate   @relation(fields: [exchangeRateId], references: [id])

  items    PurchaseItem[]
  payments PurchasePayment[]
}

// --- PLAN DE PAGOS DE COMPRAS (Cuentas por Pagar) ---
model PurchaseInstallment {
  id          Int      @id @default(autoincrement())
  purchaseId  Int
  number      Int      // Cuota #1, #2, #3...

  amount      Decimal  @db.Decimal(15, 2) // Monto de ESTA cuota
  amountPaid  Decimal  @default(0) @db.Decimal(15, 2) // Monto ya pagado de ESTA cuota

  dueDate     DateTime @db.Date           // Fecha de vencimiento de ESTA cuota
  status      InstallmentStatus @default(PENDING) 
  
  // Opcional: Si quieres registrar qué día exacto se terminó de pagar esta cuota
  paidAt      DateTime? 

  purchase    Purchase @relation(fields: [purchaseId], references: [id])
}

model PurchaseItem {
  id                    Int      @id @default(autoincrement())
  purchaseId            Int
  productId             Int
  depotId               Int
  productPresentationId Int? // <--- NUEVO: Presentación usada (caja, pack, unidad)
  quantity              Decimal  @db.Decimal(18, 6)
  unitCost              Decimal  @db.Decimal(18, 6)
  expirationDate        DateTime @db.Date

  purchase            Purchase             @relation(fields: [purchaseId], references: [id])
  product             Product              @relation(fields: [productId], references: [id])
  depot               Depot                @relation(fields: [depotId], references: [id])
  productPresentation ProductPresentation? @relation(fields: [productPresentationId], references: [id])
}

model PurchasePayment {
  id              Int           @id @default(autoincrement())
  purchaseId      Int
  paymentMethodId Int
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id]) // EFECTIVO, PAGO_MOVIL, ZELLE, ETC
  amount          Decimal       @db.Decimal(15, 2)
  //currency        String // Moneda del pago (ej: USD o VES)
  exchangeRateId  Int
  reference       String? // Nro de referencia bancaria
  paymentDate     DateTime      @default(now())

  purchase     Purchase     @relation(fields: [purchaseId], references: [id])
  exchangeRate ExchangeRate @relation(fields: [exchangeRateId], references: [id])
}

// ==========================================
// CAJA (CASH REGISTER)
// ==========================================

model CashRegister {
  id            Int        @id @default(autoincrement())
  businessId    Int
  memberId      Int
  status        CashStatus @default(OPEN)
  openTime      DateTime   @default(now())
  closeTime     DateTime?
  initialAmount Decimal    @default(0) @db.Decimal(15, 2)
  finalAmount   Decimal?   @db.Decimal(15, 2)

  business Business       @relation(fields: [businessId], references: [id])
  member   BusinessMember @relation(fields: [memberId], references: [id])
  counts   CashCount[]
  payments SalePayment[] // Relación inversa
  refunds CreditNotePayment[] // Relación inversa
}

model CashCount {
  id             Int           @id @default(autoincrement())
  cashRegisterId Int
  denomination   Decimal       @db.Decimal(10, 2) // Ej: Billete de 10, de 20...
  quantity       Int // Cuántos billetes de esa denominación
  currency       String // USD, VES
  exchangeRateId Int
  type           CashCountType // INITIAL (apertura) o FINAL (cierre)

  cashRegister CashRegister @relation(fields: [cashRegisterId], references: [id])
  exchangeRate ExchangeRate @relation(fields: [exchangeRateId], references: [id])
}

model RestaurantTable {
  id         Int         @id @default(autoincrement())
  businessId Int
  name       String      // "Mesa 1", "Mesa 2", "Terraza 3"
  capacity   Int?        // Personas que caben
  status     TableStatus @default(AVAILABLE)
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  business   Business    @relation(fields: [businessId], references: [id])
  orders     Order[]

  @@index([businessId, status])
  @@index([businessId, isActive])
}

model Order {
  id          Int         @id @default(autoincrement())
  businessId  Int
  tableId     Int?
  clientId    Int
  orderNumber Int
  status      OrderStatus @default(PENDING)
  isPaid      Boolean     @default(false)
  notes       String?
  subTotal    Decimal     @db.Decimal(15, 2)
  taxAmount   Decimal     @db.Decimal(15, 2)
  totalAmount Decimal     @db.Decimal(15, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  completedAt DateTime?

  business  Business        @relation(fields: [businessId], references: [id])
  table     RestaurantTable? @relation(fields: [tableId], references: [id])
  client    Client          @relation(fields: [clientId], references: [id])
  items     OrderItem[]

  @@index([businessId, status])
  @@index([businessId, createdAt])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Decimal @db.Decimal(18, 6)
  unitPrice Decimal @db.Decimal(15, 2)
  subTotal  Decimal @db.Decimal(15, 2)
  notes     String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model PaymentMethod {
  id       Int         @id @default(autoincrement())
  name     String // Ej: "Zelle Banesco", "Caja Chica", "Punto de Venta"
  type     PaymentType // El tipo "interno" para que el sistema sepa cómo comportarse
  isActive Boolean     @default(true) // Para ocultar cuentas viejas sin borrar historial
  currency String    // Moneda predeterminada (USD, VES)

  // Relaciones con los pagos realizados
  salePayments     SalePayment[]
  purchasePayments PurchasePayment[]
  creditNotePayments CreditNotePayment[]

  @@unique([name]) // Evita que creen dos veces "Zelle Banesco"
}

// ==========================================
// ENUMS (Listas fijas de valores)
// ==========================================

enum PlanType {
  TRIAL
  BASIC
  PREMIUM
  ENTERPRISE
}

enum SubStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELLED
}

enum SubscriptionPaymentStatus {
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum MovementType {
  IN // Entrada (Compra)
  OUT // Salida (Venta)
  ADJUSTMENT // Ajuste manual (Inventario físico)
  TRANSFER // Movimiento entre bodegas
  RETURN // Devolución
}

enum SaleType {
  RETAIL
  WHOLESALE
}

enum PurchaseStatus {
  ORDERED
  COMPLETED
  RECEIVED
  CANCELLED
}

enum PaymentType {
  CASH
  DEBIT_CARD
  CREDIT_CARD
  TRANSFER
  MOBILE_PAYMENT
  ZELLE
  OTHER
}

enum CashStatus {
  OPEN
  CLOSED
}

enum CashCountType {
  INITIAL
  FINAL
  AUDIT // Arqueo sorpresa
}

enum ExchangeRateStrategy {
  MANUAL        // El usuario escribe su tasa (ej: 40.5)
  API_BCV       // Se sincroniza auto con el Banco Central
  API_PARALLEL  // Se sincroniza auto con paralelo
}

enum ProductType {
  SIMPLE      // Producto físico estándar (se compra y se vende)
  COMPOSITE   // Receta / Combo / Kit (se compone de otros, stock calculado)
  SERVICE     // Intangible (no mueve stock)
}

enum Conditions {
  CASH
  CREDIT
}

// Renombrado a PaymentStatus para ser más claro
enum PaymentStatus {
  PENDING // No se ha pagado nada (o saldo inicial completo)
  PARTIAL // Se ha abonado algo
  PAID // Saldo en 0
  REFUNDED // Se devolvió el dinero
  // Nota: "VENCIDO" se calcula en el frontend comparando paymentDueDate vs Hoy
}

enum SaleStatus {
  DRAFT // Aún editando (carrito)
  COMPLETED // Venta cerrada y stock descontado
  CANCELLED // Venta anulada (requiere devolver stock)
}

enum InstallmentStatus {
  PARTIAL
  PENDING // Aún no se cubre el monto
  PAID    // Monto cubierto
  OVERDUE // Vencida (se calcula por fecha, pero el estado ayuda en filtros)
}

enum Currency {
  USD
  VES
  EUR
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum UnitType {
  MASS    // kg, g
  VOLUME  // L, ml
  UNIT    // pza, caja, sobre
}
