// --------------------------------------------------------
// CONFIGURACIÓN
// --------------------------------------------------------
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --------------------------------------------------------
// 1. USUARIOS Y ACCESO
// --------------------------------------------------------

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  password     String
  fullName     String
  phone        String   @default("") // Sin nulos: Si no tiene, es string vacío
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  memberships  BusinessMember[]
  
  // Auditoría: Eliminamos la autoreferencia nullable. 
  // Si necesitas auditoría estricta, se usa una tabla separada "AuditLog".
}

enum UserRole {
  OWNER
  ADMIN
  CASHIER
  AUDITOR
}

// --------------------------------------------------------
// 2. NEGOCIOS CORE
// --------------------------------------------------------

model Business {
  id             Int      @id @default(autoincrement())
  name           String
  
  // Configuración: Defaults para evitar nulos
  currencySymbol String   @default("$")
  exchangeRate   Decimal  @default(1.0) @db.Decimal(10, 4)
  address        String   @default("") 
  logoUrl        String   @default("") 

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscription   Subscription?
  members        BusinessMember[]
  
  products       Product[]
  categories     Category[]
  clients        Client[]
  suppliers      Supplier[]
  sales          Sale[]
  purchases      Purchase[]
  stockMovements StockMovement[]
  cashRegisters  CashRegister[]
  exchangeRates ExchangeRate[]
}

model ExchangeRate {
  id          Int      @id @default(autoincrement())
  businessId  Int
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  currency    String   // "VES", "EUR", "COP"
  rate        Decimal  @db.Decimal(10, 4) // Ej: 50.50
  
  // Fecha exacta en que esta tasa entró en vigencia
  createdAt   DateTime @default(now()) 
  
  // Quién creó esta tasa (Auditoría)
  createdById Int?     // Opcional, si quieres saber qué empleado la montó
  
  // RELACIONES: Todas las tablas que dependen de esta tasa
  sales       Sale[]
  salePayments    SalePayment[]
  purchasePayments PurchasePayment[]
  purchases   Purchase[]
  cashCounts  CashCount[]

  @@index([businessId, createdAt]) // Para buscar rápido la tasa de un día específico
}

model BusinessMember {
  id         Int      @id @default(autoincrement())
  
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  role       UserRole @default(CASHIER)
  isActive   Boolean  @default(true)
  joinedAt   DateTime @default(now())

  sales          Sale[]
  purchases      Purchase[]
  stockMovements StockMovement[]
  cashRegisters  CashRegister[]

  @@unique([userId, businessId])
}

// --------------------------------------------------------
// 3. LICENCIAS
// --------------------------------------------------------

model Subscription {
  id             Int        @id @default(autoincrement())
  businessId     Int        @unique
  business       Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  planType       String     
  status         PlanStatus @default(TRIALING)
  
  startDate      DateTime   @default(now())
  endDate        DateTime   
  
  lastPaymentRef String     @default("") // Sin nulos

  @@index([status]) // Índice para búsquedas rápidas de bloqueo
}

enum PlanStatus {
  TRIALING
  ACTIVE
  EXPIRED
  CANCELED
}

// --------------------------------------------------------
// 4. INVENTARIO (NORMALIZADO)
// --------------------------------------------------------

model Category {
  id         Int       @id @default(autoincrement())
  businessId Int
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  products   Product[]
  
  @@unique([businessId, name])
}

model Product {
  id          Int      @id @default(autoincrement())
  businessId  Int
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  // NORMALIZACIÓN: Un producto DEBE tener categoría.
  // Backend: Crear categoría "General" automática al crear el negocio.
  categoryId  Int      
  category    Category @relation(fields: [categoryId], references: [id]) 
  
  name        String
  sku         String   @default("") // Si no tiene, string vacío (o generar UUID)
  description String   @default("")
  imageUrl    String   @default("")
  
  costPrice   Decimal  @db.Decimal(10, 2) @default(0.00)
  salePrice   Decimal  @db.Decimal(10, 2) @default(0.00)
  
  stock       Int      @default(0)
  minStock    Int      @default(5)
  isService   Boolean  @default(false)
  
  saleItems   SaleItem[]
  purchaseItems PurchaseItem[]
  movements   StockMovement[]

  @@unique([businessId, sku]) // OJO: Si SKU es vacío, cuidado con duplicados vacíos.
}

// --------------------------------------------------------
// 5. VENTAS (ESTRICTO)
// --------------------------------------------------------

model Sale {
  id           Int      @id @default(autoincrement())
  businessId   Int
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  memberId     Int
  member       BusinessMember @relation(fields: [memberId], references: [id])
  
  // NORMALIZACIÓN: Toda venta debe tener cliente.
  // Backend: Usar un "Cliente Público/Genérico" si es venta anónima.
  clientId     Int      
  client       Client   @relation(fields: [clientId], references: [id])
  
  totalAmount  Decimal  @db.Decimal(12, 2)
  exchangeRateId Int
  exchangeRate   ExchangeRate @relation(fields: [exchangeRateId], references: [id])
  
  status       SaleStatus @default(COMPLETED)
  createdAt    DateTime @default(now())
  
  items        SaleItem[]
  salePayments     SalePayment[]
}

enum SaleStatus {
  COMPLETED
  PENDING_PAYMENT
  CANCELED
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  subTotal  Decimal @db.Decimal(10, 2)
}

model SalePayment {
  id           Int      @id @default(autoincrement())
  saleId       Int
  sale         Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  method       PaymentMethod
  
  amount       Decimal  @db.Decimal(12, 2)
  currency     String   
  exchangeRateId Int
  exchangeRate   ExchangeRate @relation(fields: [exchangeRateId], references: [id])
  
  reference    String   @default("") // Sin nulos
  date         DateTime @default(now())
	@@map("Payment")
}

enum PaymentMethod {
  CASH
  DEBIT_CARD
  CREDIT_CARD
  MOBILE_PAYMENT
  TRANSFER
  ZELLE
  OTHER
}

// --------------------------------------------------------
// 6. TERCEROS
// --------------------------------------------------------

model Client {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  name       String
  documentId String   @default("") 
  phone      String   @default("")
  email      String   @default("")
  address    String   @default("")
  
  sales      Sale[]
}

model Supplier {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  name       String
  contact    String   @default("")
  phone      String   @default("")
  
  purchases  Purchase[]
}

model Purchase {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  // Compra siempre tiene proveedor (Crear "Proveedor Genérico" si es necesario)
  supplierId Int      
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  
  memberId   Int
  member     BusinessMember @relation(fields: [memberId], references: [id])
  
  totalCost  Decimal  @db.Decimal(12, 2)

  exchangeRateId Int
  exchangeRate   ExchangeRate @relation(fields: [exchangeRateId], references: [id])
  
  date       DateTime @default(now())
  
  items      PurchaseItem[]
  payments   PurchasePayment[]
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])
  
  quantity   Int
  unitCost   Decimal  @db.Decimal(10, 2)
}

model PurchasePayment {
  id             Int      @id @default(autoincrement())
  purchaseId     Int
  purchase       Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  
  // ¿Cómo pagaste?
  method         PaymentMethod // Usamos el mismo Enum que en ventas (CASH, ZELLE, etc)
  
  // ¿Cuánto dinero salió de tu bolsillo?
  amount         Decimal  @db.Decimal(12, 2) 
  currency       String   // "USD", "VES"
  
  // IMPORTANTE: Tasa del momento del PAGO.
  // Si pagas una deuda 15 días después, la tasa será distinta a la de la factura.
  exchangeRateId Int
  exchangeRate   ExchangeRate @relation(fields: [exchangeRateId], references: [id])
  
  reference      String   @default("") // Nro de confirmación bancaria
  paymentDate    DateTime @default(now())
}

// --------------------------------------------------------
// 7. KARDEX
// --------------------------------------------------------

model StockMovement {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  productId  Int
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  memberId   Int
  member     BusinessMember @relation(fields: [memberId], references: [id])
  
  type       MovementType
  quantity   Int      
  reason     String   @default("") // Sin nulos
  date       DateTime @default(now())
}

enum MovementType {
  SALE
  PURCHASE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN
}

// --------------------------------------------------------
// 8. CAJA (CORREGIDO PARA 1NF - SIN JSON)
// --------------------------------------------------------

model CashRegister {
  id            Int      @id @default(autoincrement())
  businessId    Int
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  memberId      Int
  member        BusinessMember @relation(fields: [memberId], references: [id])
  
  // Estado de la caja
  status        RegisterStatus @default(OPEN)
  
  openTime      DateTime @default(now())
  // OJO: "closeTime" DEBE ser nulo lógica y físicamente si la caja está abierta.
  // Poner una fecha dummy (ej: año 1970) es mala práctica. 
  // Para normalizar estrictamente, separamos el cierre en otra tabla 
  // O aceptamos este único nulo necesario.
  // Opción elegida: Aceptar nulo aquí, o usar tabla separada "CashRegisterClosing".
  // MANTENDRÉ closeTime NULO porque es un "estado temporal". 
  // Si insistes en NO NULL, requiere una tabla hija "RegisterClosing".
  closeTime     DateTime? 

  initialAmount Decimal  @db.Decimal(12, 2)
  finalAmount   Decimal  @db.Decimal(12, 2) @default(0.00)
  
  // Relación 1 a Muchos para el desglose de dinero (Sustituye al JSON)
  cashCounts    CashCount[]
}

enum RegisterStatus {
  OPEN
  CLOSED
}

// Nueva tabla para Normalizar el JSON de "detalles de billetes"
model CashCount {
  id             Int          @id @default(autoincrement())
  cashRegisterId Int
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  
  denomination   Decimal      @db.Decimal(10, 2) // Ej: 10.00, 20.00, 100.00
  quantity       Int          // Ej: 5 billetes

  exchangeRateId Int
  exchangeRate   ExchangeRate @relation(fields: [exchangeRateId], references: [id])
  
  currency       String       // "USD", "VES"
  type           CountType    // INICIAL o FINAL
}

enum CountType {
  OPENING
  CLOSING
}

// --------------------------------------------------------
// EXTRAS
// --------------------------------------------------------
generator erd {
  provider = "prisma-erd-generator"
  output   = "../ERD.svg"
}