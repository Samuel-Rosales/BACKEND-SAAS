// --------------------------------------------------------
// CONFIGURACIÓN
// --------------------------------------------------------
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --------------------------------------------------------
// 1. USUARIOS Y ACCESO (GLOBAL)
// --------------------------------------------------------

model User {
  id            Int              @id @default(autoincrement())
  email         String           @unique
  password      String
  fullName      String
  phone         String           @default("") 
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())

  memberships   BusinessMember[]
  
  // Auditoría: Relación inversa para saber qué modificó este usuario
  updatedProducts Product[]      @relation("ProductUpdates")
}

enum UserRole {
  OWNER    // Dueño
  ADMIN    // Gerente
  CASHIER  // Cajero
  AUDITOR  // Contador
}

// --------------------------------------------------------
// 2. NEGOCIOS CORE
// --------------------------------------------------------

model Business {
  id             Int              @id @default(autoincrement())
  name           String
  
  // Configuración
  currencySymbol String           @default("$")
  exchangeRate   Decimal          @default(1.0) @db.Decimal(10, 4) // Tasa "Pizarra" actual
  address        String           @default("") 
  logoUrl        String           @default("") 

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  subscription   Subscription?
  members        BusinessMember[]
  
  // Datos Operativos
  products       Product[]
  categories     Category[]
  clients        Client[]
  suppliers      Supplier[]
  sales          Sale[]
  purchases      Purchase[]
  stockMovements StockMovement[]
  cashRegisters  CashRegister[]
  exchangeRates  ExchangeRate[]   // Historial de tasas
}

// Tabla Central de Tasas (Integridad Financiera)
model ExchangeRate {
  id             Int              @id @default(autoincrement())
  businessId     Int
  business       Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)

  currency       String           // "VES", "EUR", "COP"
  rate           Decimal          @db.Decimal(10, 4) // Ej: 50.50
  
  createdAt      DateTime         @default(now()) 
  createdById    Int?             // Auditoría: Quién creó la tasa
  
  // Relaciones Financieras
  sales            Sale[]
  salePayments     SalePayment[]
  purchases        Purchase[]
  purchasePayments PurchasePayment[]
  cashCounts       CashCount[]

  @@index([businessId, createdAt])
}

model BusinessMember {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId  Int
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  role        UserRole @default(CASHIER)
  isActive    Boolean  @default(true)
  joinedAt    DateTime @default(now())

  sales          Sale[]
  purchases      Purchase[]
  stockMovements StockMovement[]
  cashRegisters  CashRegister[]

  @@unique([userId, businessId])
}

// --------------------------------------------------------
// 3. LICENCIAS
// --------------------------------------------------------

model Subscription {
  id             Int        @id @default(autoincrement())
  businessId     Int        @unique
  business       Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  planType       String     
  status         PlanStatus @default(TRIALING)
  
  startDate      DateTime   @default(now())
  endDate        DateTime   
  
  lastPaymentRef String     @default("")

  @@index([status]) 
}

enum PlanStatus {
  TRIALING
  ACTIVE
  EXPIRED
  CANCELED
}

// --------------------------------------------------------
// 4. INVENTARIO
// --------------------------------------------------------

model Category {
  id         Int       @id @default(autoincrement())
  businessId Int
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  products   Product[]
  
  @@unique([businessId, name])
}

model Product {
  id          Int      @id @default(autoincrement())
  businessId  Int
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  categoryId  Int      
  category    Category @relation(fields: [categoryId], references: [id]) 
  
  name        String
  sku         String   @default("") 
  description String   @default("")
  imageUrl    String   @default("")
  
  costPrice   Decimal  @db.Decimal(10, 2) @default(0.00)
  salePrice   Decimal  @db.Decimal(10, 2) @default(0.00)
  
  stock       Int      @default(0)
  minStock    Int      @default(5)
  isService   Boolean  @default(false)

  // Auditoría (RNF-04)
  updatedAt   DateTime @updatedAt
  updatedById Int?     
  updatedBy   User?    @relation("ProductUpdates", fields: [updatedById], references: [id])
  
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]
  movements     StockMovement[]

  @@unique([businessId, sku]) 
}

// --------------------------------------------------------
// 5. VENTAS (CORE)
// --------------------------------------------------------

enum SaleType {
  IMMEDIATE // Contado / Normalita
  CREDIT    // A Crédito
}

enum SaleStatus {
  COMPLETED       // Pagada totalmente
  PENDING_PAYMENT // Debe dinero
  CANCELED        // Anulada
}

model Sale {
  id             Int          @id @default(autoincrement())
  businessId     Int
  business       Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  // Número de Recibo Secuencial (RF-12)
  receiptNumber  Int          

  memberId       Int
  member         BusinessMember @relation(fields: [memberId], references: [id])
  
  clientId       Int      
  client         Client   @relation(fields: [clientId], references: [id])
  
  // --- FINANZAS ---
  
  // Tipo de Venta (Lo que acabamos de agregar)
  type           SaleType     @default(IMMEDIATE)

  totalAmount    Decimal      @db.Decimal(12, 2)
  
  // Control de Crédito (RF-13, RF-14)
  remainingBalance Decimal    @db.Decimal(12, 2) @default(0.00)
  paymentDueDate   DateTime?  // Fecha límite para pagar (RF-15)

  // Integridad Histórica
  exchangeRateId Int
  exchangeRate   ExchangeRate @relation(fields: [exchangeRateId], references: [id])
  
  status         SaleStatus   @default(COMPLETED)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt 
  
  items          SaleItem[]
  salePayments   SalePayment[]
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  subTotal  Decimal @db.Decimal(10, 2)
}

model SalePayment {
  id             Int          @id @default(autoincrement())
  saleId         Int
  sale           Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  method         PaymentMethod
  amount         Decimal      @db.Decimal(12, 2)
  currency       String 
  
  exchangeRateId Int
  exchangeRate   ExchangeRate @relation(fields: [exchangeRateId], references: [id])
  
  reference      String       @default("") 
  date           DateTime     @default(now())
}

enum PaymentMethod {
  CASH
  DEBIT_CARD
  CREDIT_CARD
  MOBILE_PAYMENT
  TRANSFER
  ZELLE
  OTHER
}

// --------------------------------------------------------
// 6. COMPRAS Y PROVEEDORES
// --------------------------------------------------------

model Supplier {
  id         Int        @id @default(autoincrement())
  businessId Int
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  contact    String     @default("")
  phone      String     @default("")
  purchases  Purchase[]
}

enum PurchaseStatus {
  COMPLETED
  PENDING
  CANCELED
}

model Purchase {
  id             Int             @id @default(autoincrement())
  businessId     Int
  business       Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  supplierId     Int      
  supplier       Supplier        @relation(fields: [supplierId], references: [id])
  
  memberId       Int
  member         BusinessMember  @relation(fields: [memberId], references: [id])
  
  totalCost      Decimal         @db.Decimal(12, 2)
  
  status         PurchaseStatus  @default(COMPLETED) // Control de deuda a proveedor

  exchangeRateId Int
  exchangeRate   ExchangeRate    @relation(fields: [exchangeRateId], references: [id])
  
  date           DateTime        @default(now())
  
  items          PurchaseItem[]
  payments       PurchasePayment[]
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])
  
  quantity   Int
  unitCost   Decimal  @db.Decimal(10, 2)
}

model PurchasePayment {
  id             Int          @id @default(autoincrement())
  purchaseId     Int
  purchase       Purchase     @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  
  method         PaymentMethod 
  amount         Decimal      @db.Decimal(12, 2) 
  currency       String   
  
  exchangeRateId Int
  exchangeRate   ExchangeRate @relation(fields: [exchangeRateId], references: [id])
  
  reference      String       @default("") 
  paymentDate    DateTime     @default(now())
}

// --------------------------------------------------------
// 7. KARDEX Y CLIENTES
// --------------------------------------------------------

model Client {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  name       String
  documentId String   @default("") 
  phone      String   @default("")
  email      String   @default("")
  address    String   @default("")
  
  sales      Sale[]
}

model StockMovement {
  id         Int            @id @default(autoincrement())
  businessId Int
  business   Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  memberId   Int
  member     BusinessMember @relation(fields: [memberId], references: [id])
  
  type       MovementType
  quantity   Int      
  reason     String         @default("") 
  date       DateTime       @default(now())
}

enum MovementType {
  SALE
  PURCHASE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN
}

// --------------------------------------------------------
// 8. CAJA
// --------------------------------------------------------

model CashRegister {
  id             Int            @id @default(autoincrement())
  businessId     Int
  business       Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  memberId       Int
  member         BusinessMember @relation(fields: [memberId], references: [id])
  
  status         RegisterStatus @default(OPEN)
  
  openTime       DateTime       @default(now())
  closeTime      DateTime? 

  initialAmount  Decimal        @db.Decimal(12, 2)
  finalAmount    Decimal        @db.Decimal(12, 2) @default(0.00)
  
  cashCounts     CashCount[]
}

enum RegisterStatus {
  OPEN
  CLOSED
}

model CashCount {
  id             Int          @id @default(autoincrement())
  cashRegisterId Int
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  
  denomination   Decimal      @db.Decimal(10, 2) 
  quantity       Int          

  exchangeRateId Int
  exchangeRate   ExchangeRate @relation(fields: [exchangeRateId], references: [id])
  
  currency       String       
  type           CountType    
}

enum CountType {
  OPENING
  CLOSING
}

// --------------------------------------------------------
// EXTRAS
// --------------------------------------------------------
generator erd {
  provider = "prisma-erd-generator"
  output   = "../ERD.svg"
}